# از my.telegram.org (بخش API Development Tools) بگیرید
TG_API_ID=
TG_API_HASH=

# با اجرای scripts/login.js روی کامپیوتر خودتون تولید میشه
SESSION_STRING=

# توکن باتی که از BotFather گرفتید (بات کوچیک رله)
TELEGRAM_BOT_TOKEN=

# آیدی عددی چت بین اکانت شخصی (یوزربات) و بات رله
# (بعد از /start زدن به بات از اکانت شخصی، از @userinfobot یا لاگ بات میشه گرفت)
RELAY_CHAT_ID=

# آدرس دامنه‌ای که Vercel بهتون میده، بعد از اولین دیپلوی پرش کنید
PUBLIC_BASE_URL=
